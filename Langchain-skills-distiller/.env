# Skills Agent 环境变量配置
# 复制此文件为 .env 并填入你的配置


# =============================================================================
# 方式一：使用 Anthropic Claude (默认)
# =============================================================================
# API Key
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# 代理地址（可选，用于访问受限网络）
ANTHROPIC_BASE_URL=

# Claude 模型名称（通用，切换为 Qwen 时在下方通义千问区域设置）
# 可选值: claude-sonnet-4-20250601, claude-opus-4-20250514 等
# CLAUDE_MODEL=claude-sonnet-4-20250601

# 模型最大输出 token 数
MAX_TOKENS=16000

# 模型温度参数（0.0-2.0）
MODEL_TEMPERATURE=1.0

# 思考模式的 token 预算
THINKING_BUDGET=10000


# =============================================================================
# 方式二：使用通义千问 Qwen (阿里云 DashScope)
# =============================================================================
# DashScope API Key (在阿里云控制台获取: https://dashscope.console.aliyun.com/)
# 示例格式: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_API_KEY=sk-d1bbb66d8c174a4d81007346a7bc27a8

# 通义千问模型名称（可选，默认为 qwen-turbo）
# 可选值: qwen-turbo, qwen-plus, qwen-max, qwen-long, qwen3-coder-plus 等
CLAUDE_MODEL=qwen-turbo

# 通义千问默认模型（用于自动选择）
QWEN_DEFAULT_MODEL=qwen-turbo

# Qwen 模型名前缀列表（逗号分隔，用于判断是否走 Qwen 通道）
QWEN_MODEL_PREFIXES=qwen-,qwen-turbo,qwen-plus,qwen-max,qwen-long

# 自定义 API Base URL（必须，DashScope 兼容模式端点）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


# =============================================================================
# 通用配置
# =============================================================================
# 最大对话轮数限制
MAX_TURNS=20

# 调试日志
SKILLS_DEBUG=1
